---
import { sanity } from "../lib/sanityClient";
import { siteSettingsQuery } from "../lib/queries";

import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const siteSettings = await sanity.fetch(siteSettingsQuery);

type Props = {
  title?: string;
  description?: string;
};

const {
  title,
  description,
} = Astro.props;

const finalTitle =
  title ?? siteSettings?.defaultSeo?.title ?? "One Handy Katie";

const finalDescription =
  description ??
  siteSettings?.defaultSeo?.description ??
  "Handywoman services, home repair assessments, and construction project management.";


// Helps with canonical + og:url. Configure site in astro.config for best results.
const siteUrl = Astro.site?.toString() ?? "https://your-site.netlify.app";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/logo/OHK_icon_logo.png" />

    <!-- Local SEO: structured data -->
    <script type="application/ld+json" is:inline>
      {JSON.stringify(
        {
          "@context": "https://schema.org",
          "@type": "HomeAndConstructionBusiness",
          name: siteSettings?.businessName ?? "One Handy Katie",
          description: "Handywoman services, home repairs, and construction project management serving Greeley, Fort Collins, Loveland, and the Colorado Front Range.",
          telephone: siteSettings?.phone,
          email: siteSettings?.email,
          url: siteUrl,
          address: {
            "@type": "PostalAddress",
            addressLocality: siteSettings?.address?.city ?? "Greeley",
            addressRegion: siteSettings?.address?.state ?? "CO",
            postalCode: siteSettings?.address?.postalCode,
            streetAddress: siteSettings?.address?.streetAddress,
            addressCountry: "US",
          },
          areaServed: (
            (siteSettings?.serviceArea?.length ? siteSettings.serviceArea : [
              "Greeley, CO",
              "Fort Collins, CO",
              "Loveland, CO",
              "Evans, CO",
              "Windsor, CO",
              "Weld County, CO",
              "Larimer County, CO",
            ])
          ).map((name: string) => ({ "@type": "City", name })),
          knowsAbout: [
            "home repair",
            "handywoman services",
            "construction project management",
            "home improvement",
            "smart home installation",
          ],
          sameAs: [
            siteSettings?.social?.facebook,
            siteSettings?.social?.instagram,
            siteSettings?.social?.nextdoor,
          ].filter(Boolean),
        },
        null,
        2
      )}
    </script>
  </head>

  <body>
    <Header siteSettings={siteSettings} />
    <main class="container">
      <slot />
    </main>
    <Footer siteSettings={siteSettings} />
  </body>
</html>
