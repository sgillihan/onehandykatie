---
const { siteSettings } = Astro.props;

// Helpers
const businessName = siteSettings?.businessName ?? "One Handy Katie";
const phoneRaw = siteSettings?.phone ?? ""; // can be "(970)..." or "+1..."
const email = siteSettings?.email ?? "";
const serviceArea = siteSettings?.serviceArea ?? [];

// Make a tel: link safe-ish even if Katie types punctuation/spaces
const telHref = phoneRaw ? `tel:${phoneRaw.replace(/[^\d+]/g, "")}` : "";
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <img
        src="/logo/OHK_icon_logo.png"
        alt={`${businessName} — Fix. Advise. Manage.`}
        class="footer-logo"
        loading="lazy"
        decoding="async"
      />
    </div>

    <div>
      <strong>Service Area</strong>
      {serviceArea.length ? (
        <p class="muted">{serviceArea.join(", ")}</p>
      ) : (
        <p class="muted">Greeley, Colorado and the Colorado Front Range area</p>
      )}
    </div>

    <div>
      <strong>Contact</strong>
      <p class="muted">
        {phoneRaw ? (
          <>
            <a href={telHref}>{phoneRaw}</a><br />
          </>
        ) : null}

        {email ? (
          <>
            <a href={`mailto:${email}`}>{email}</a><br />
          </>
        ) : null}

        <a href="/contact">Request an estimate</a>
      </p>
    </div>

    <div>
      <strong>Services</strong>
      <p class="muted">
        <a href="/services/#fix">Home repairs</a><br />
        <a href="/services/#advise">Project advice</a><br />
        <a href="/services/#manage">Project management</a>
      </p>
    </div>
  </div>

  <div class="container copyright">
    <p class="muted">
      © {new Date().getFullYear()} {businessName}. All rights reserved.
    </p>
  </div>

  <style>
    .site-footer {
      border-top: 1px solid #eee;
      margin-top: 3rem;
      padding: 2rem 0;
      background: #fafafa;
    }
    .footer-inner {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.5rem;
    }
    .footer-brand {
      display: flex;
      align-items: center;
    }

    .footer-logo {
      height: 64px;   /* adjust if needed */
      width: auto;
    }

    .muted { opacity: 0.8; margin: 0.5rem 0 0; }
    .copyright { margin-top: 1.25rem; }
    @media (max-width: 900px) {
      .footer-inner { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @media (max-width: 600px) {
      .footer-inner { grid-template-columns: 1fr; }
    }
  </style>
</footer>
