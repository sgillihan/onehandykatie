---
const nav = [
  { href: "/", label: "Home" },
  { href: "/services", label: "Services" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="/">
      <span class="brand-name">One Handy Katie</span>
      <span class="brand-tag">Handywoman • Project Management</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav">
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <a class="button cta" href="/contact">Request an Estimate</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    background: white;
    border-bottom: 1px solid #eee;
    z-index: 50;
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
  }
  .brand {
    display: grid;
    gap: 0.1rem;
  }
  .brand-name { font-weight: 800; }
  .brand-tag { font-size: 0.9rem; opacity: 0.8; }

  .nav {
    list-style: none;
    display: flex;
    gap: 0.9rem;
    padding: 0;
    margin: 0;
  }
  .nav a { padding: 0.35rem 0.25rem; }

  .cta { margin-left: auto; }

  /* Mobile: collapse nav */
  @media (max-width: 800px) {
    .header-inner { flex-wrap: wrap; }
    nav { width: 100%; }
    .nav { flex-wrap: wrap; }
    .cta { margin-left: 0; }
  }
</style>
