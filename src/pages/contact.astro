---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | One Handy Katie"
  description="Request an estimate or ask a question about your home project."
>
  <section class="section">
    <h1>Request an Estimate</h1>
    <p class="muted">
      Share a few details about your project and I’ll follow up to schedule a call or visit.
    </p>

    <form
      name="estimate"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="form"
      action="/thanks/"
    >
      <!-- Netlify required hidden field -->
      <input type="hidden" name="form-name" value="estimate" />

      <!-- Honeypot (hidden from humans) -->
      <p class="hidden">
        <label>
          Don’t fill this out: <input name="bot-field" />
        </label>
      </p>

      <div class="grid">
        <label>
          Your name
          <input name="name" type="text" required />
        </label>

        <label>
          Email
          <input name="email" type="email" required />
        </label>

        <label>
          Phone
          <input name="phone" type="tel" />
        </label>

        <label>
          City
          <input name="location" type="text" required />
        </label>
      </div>

      <label>
        What type of project is this?
        <select name="projectType" required>
          <option value="" selected disabled>Select one</option>
          <option>Fix: Repairs, small remodels, handywoman services</option>
          <option>Advise: Get help assessing the scope of your project/problem/repair</option>
          <option>Manage: Large scale remodeling or construction projects</option>
          <option>Not sure yet</option>
        </select>
      </label>

      <label>
        Tell me about the project
        <textarea name="message" rows="6" required></textarea>
      </label>

      <label>
        Ideal timeline for project start
        <select name="timeline" required>
          <option value="" selected disabled>Select one</option>
          <option>ASAP</option>
          <option>1–2 weeks</option>
          <option>2–4 weeks</option>
          <option>1–2 months</option>
          <option>Flexible</option>
        </select>
      </label>

      <button class="button primary" type="submit">Send request</button>

      <p class="muted small">
        By submitting, you agree to be contacted about this request. No spam.
      </p>
    </form>
  </section>

  <style>
    .muted { opacity: 0.8; }
    .small { font-size: 0.95rem; }
    .form {
      margin-top: 1rem;
      display: grid;
      gap: 1rem;
      max-width: 720px;
    }
    label { display: grid; gap: 0.35rem; font-weight: 600; }
    input, select, textarea {
      font: inherit;
      padding: 0.75rem 0.9rem;
      border-radius: 0.75rem;
      border: 1px solid #ddd;
      background: white;
    }
    textarea { resize: vertical; }
    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .hidden { display: none; }
    @media (max-width: 700px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
