---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanity } from "../lib/sanityClient";
import groq from "groq";

const serviceArea = "Serving Greeley, Fort Collins, Loveland, and the Colorado Front Range";
const phone = "(970) 302-8294"; //update as needed

const gallery = await sanity.fetch(groq`*[_type == "homepageGallery"][0]{
  "photos": photos[]{
    caption,
    "imageUrl": image.asset->url
  }
}`);
---

<BaseLayout
  title="Handywoman Services in Greeley, Fort Collins & Loveland CO | One Handy Katie"
  description="One Handy Katie provides handywoman services, home repairs, and construction project management in Greeley, Fort Collins, and Loveland, CO. 25 years of experience. Request a free estimate."
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid">
      <div>
        <h1 class="sr-only">Handywoman &amp; Home Repair Services in Greeley, Fort Collins &amp; Loveland, CO — One Handy Katie</h1>
        <img
          src="/logo/OHK_primary_logo.png"
          alt="One Handy Katie — Fix. Advise. Manage."
          class="primary-logo"
          width="600"
          height="300"
          loading="eager"
          decoding="async"
        />
        <p class="eyebrow">{serviceArea}</p>
        <p class="lead">
          Handywoman services, home repair / project scope assessment, & project management
        </p>

        <div class="actions">
          <a class="button primary" href="/contact">Request an Estimate</a>
          <a class="button" href="/services">View Services</a>
        </div>

        <p class="micro">
          Prefer to talk or text? <a href={`tel:${phone.replace(/[^\d+]/g, "")}`}>Contact {phone}</a>
        </p>
      </div>

      <div class="hero-card" aria-label="Quick highlights">
        <h2>How I can help</h2>
        <ul class="checklist">
          <li><a href="/services/#fix">Fix- take care of home repairs and other handywoman tasks</a></li>
          <li><a href="/services/#advise">Advise- advise you on your home problem or project</a></li>
          <li><a href="/services/#manage">Manage- provide full project management services for larger projects</a></li>
        </ul>

        <div class="trust">
          <div class="trust-item">
            <strong>Experience</strong>
            <span>20 years of construction project management experience, including medical grade construction.</span>
          </div>
          <div class="trust-item">
            <strong>Quality</strong>
            <span>Code & Standards compliance, quality materials, and the right tools for the job.</span>
          </div>
          <div class="trust-item">
            <strong>Value</strong>
            <span>Competitive pricing, smart sourcing, and attention to your budget.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECT GALLERY -->
  {(gallery?.photos?.length ?? 0) > 0 && (
    <section class="section">
      <div class="section-head">
        <h2>Recent Projects</h2>
      </div>
      <div class="gallery-scroll">
        {gallery.photos.map((p: { imageUrl?: string; caption?: string }) => (
          <figure class="gallery-thumb">
            <img src={p.imageUrl} alt={p.caption ?? "Project photo"} loading="lazy" />
            {p.caption && <figcaption>{p.caption}</figcaption>}
          </figure>
        ))}
      </div>
    </section>
  )}

  <!-- PROCESS -->
  <section class="section">
    <div class="section-head">
      <h2>Simple process</h2>
      <p class="muted">Clear steps, no surprises.</p>
    </div>

    <ol class="steps">
      <li>
        <strong>Tell me about the project</strong>
        <p class="muted">Send photos, goals, and your timeline.</p>
      </li>
      <li>
        <strong>Scope and estimate</strong>
        <p class="muted">We confirm details and set expectations.</p>
      </li>
      <li>
        <strong>Schedule and complete</strong>
        <p class="muted">Quality work, tidy finish, and updates.</p>
      </li>
    </ol>
  </section>

  <!-- CTA -->
  <section class="cta-band">
    <div class="cta-inner">
      <div>
        <h2>Ready to get started?</h2>
        <p class="muted">Request an estimate and I’ll follow up with next steps.</p>
      </div>
      <a class="button primary" href="/contact">Request an Estimate</a>
    </div>
  </section>

  <style>
    /* HERO */
    .hero { padding: 2rem 0 1rem; }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 2rem;
      align-items: start;
    }
    .eyebrow { opacity: 0.8; margin: 0 0 0.5rem; }
    h1 { font-size: clamp(2rem, 3.5vw, 3rem); line-height: 1.1; margin: 0 0 0.75rem; }
    .primary-logo {
      max-width: 520px;
      width: 100%;
      height: auto;
      margin: 0 0 1rem;
    }
    .lead { font-size: 1.1rem; opacity: 0.9; max-width: 52ch; }

    .actions { display: flex; gap: 0.75rem; margin: 1.25rem 0 0.5rem; flex-wrap: wrap; }
    .micro { font-size: 0.95rem; opacity: 0.85; margin-top: 0.5rem; }

    .hero-card {
      border: 1px solid #eee;
      border-radius: 1rem;
      padding: 1.25rem;
      background: #fafafa;
    }
    .hero-card h2 { margin: 0 0 0.75rem; font-size: 1.1rem; }
    .checklist { margin: 0; padding-left: 1.2rem; }
    .checklist li { margin: 0.5rem 0; }

    .trust {
      display: grid;
      gap: 0.75rem;
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid #eaeaea;
    }
    .trust-item span { display: block; font-size: 0.95rem; opacity: 0.8; margin-top: 0.15rem; }
    .trust-item strong::before {
      content: "✓ ";
      color: #2563eb;
      font-weight: 700;
    }

    /* SECTION HEAD */
    .section-head { margin-bottom: 1rem; }
    .section-head h2 { margin: 0 0 0.35rem; }
    .muted { opacity: 0.8; }

    /* PROJECT GALLERY */
    .gallery-scroll {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      padding-bottom: 0.75rem;
      scroll-snap-type: x mandatory;
    }
    .gallery-scroll::-webkit-scrollbar { height: 6px; }
    .gallery-scroll::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 3px; }
    .gallery-scroll::-webkit-scrollbar-thumb { background: #ccc; border-radius: 3px; }
    .gallery-thumb {
      flex: 0 0 240px;
      scroll-snap-align: start;
      border-radius: 0.75rem;
      overflow: hidden;
      border: 1px solid #eee;
      background: white;
      margin: 0;
    }
    .gallery-thumb img {
      width: 100%;
      height: 180px;
      object-fit: cover;
      display: block;
    }
    .gallery-thumb figcaption {
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      color: #444;
    }

    /* STEPS */
    .steps {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      list-style: none;
      padding: 0;
      margin: 1rem 0 0;
      counter-reset: step;
    }
    .steps li {
      border: 1px solid #eee;
      border-radius: 1rem;
      padding: 1rem;
      background: white;
    }
    .steps li strong { display: block; margin-bottom: 0.35rem; }

    /* CTA BAND */
    .cta-band {
      margin: 2rem 0 3rem;
      padding: 1.5rem 0;
      border-top: 1px solid #eee;
      border-bottom: 1px solid #eee;
      background: #fafafa;
    }
    .cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .hero-grid { grid-template-columns: 1fr; }
      .steps { grid-template-columns: 1fr; }
      .cta-inner { flex-direction: column; align-items: flex-start; }
    }
  </style>
</BaseLayout>
